{
  "manifest_version": 3,
  "name": "CP-Lockin",
  "version": "1.0.0",
  "description": "Track your competitive programming progress on Codeforces and LeetCode.",

  "permissions": ["storage", "alarms"],

  "host_permissions": [
    "https://codeforces.com/*",
    "https://leetcode.com/*"
  ],

  "content_scripts": [
    {
      "matches": ["https://codeforces.com/submissions/*"],
      "js": [
        "src/utils/browserShim.js",
        "src/content/codeforcesSubmissionsScraper.js"
      ]
    }
  ],

  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "96": "icons/icon96.png"
    },
    "default_title": "CP-Lockin"
  },

  "background": {
    "service_worker": "src/background/service-worker.js"
  },

  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": false
  },

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "96": "icons/icon96.png"
  }
}
